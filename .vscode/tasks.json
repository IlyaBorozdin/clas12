{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile ROOT macros (Fast Check)",
            "type": "shell",
            "command": "/opt/homebrew/bin/root",
            "args": [
                "-b",
                "-l",
                "-q",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Compile CLAS12ROOT macros (Fast Check)",
            "type": "shell",
            "command": "/Users/boroz/clas12root/bin/clas12root",
            "args": [
                "-b",
                "-l",
                "-q",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}